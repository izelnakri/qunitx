{
  "name": "qunitx",
  "type": "module",
  "version": "1.2.10",
  "description": "Universal test library — run the same test file in Node.js, Deno, and the browser with QUnit's battle-tested assertion API",
  "author": "Izel Nakri",
  "license": "MIT",
  "keywords": [
    "test",
    "testing",
    "automated testing",
    "test framework",
    "ui testing",
    "e2e",
    "e2e testing",
    "0 dependencies",
    "zero dependencies",
    "no dependencies",
    "universal testing",
    "universal test framework",
    "universal test",
    "universal",
    "cross platform",
    "cross platform testing",
    "cross platform test framework",
    "cross platform test",
    "unit testing",
    "unit test",
    "unit",
    "integration testing",
    "integration test",
    "integration",
    "qa",
    "quality assurance",
    "tdd",
    "bdd",
    "assert",
    "frontend",
    "backend",
    "qunit",
    "qunit-plugin",
    "node",
    "deno",
    "browser"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "qunitx": {
      "types": "./dist/node/index.d.ts",
      "deno": "./dist/deno/index.js",
      "node": "./dist/node/index.js",
      "default": "./dist/browser/index.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "deno": "./dist/deno/index.js",
      "node": "./dist/node/index.js",
      "default": "./dist/browser/index.js"
    },
    "./assert": {
      "types": "./dist/shared/assert.d.ts",
      "deno": "./shims/shared/assert.ts",
      "default": "./dist/shared/assert.js"
    }
  },
  "files": [
    "dist/",
    "shims/deno/",
    "shims/shared/",
    "shims/types.ts",
    "vendor/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izelnakri/qunitx.git"
  },
  "scripts": {
    "format": "prettier --check \"test/**/*.ts\" \"*.ts\" \"package.json\"",
    "format:fix": "prettier --write \"test/**/*.ts\" \"*.ts\" \"package.json\"",
    "lint": "deno lint shims/",
    "lint:docs": "deno doc --lint shims/deno/module.ts shims/deno/test.ts",
    "build": "node build.ts",
    "build:cold": "rm -rf dist && node build.ts",
    "pretest": "node build.ts && node --input-type=module -e \"import{symlinkSync}from'fs';try{symlinkSync('..','node_modules/qunitx','junction')}catch(_){}\"",
    "run:all": "npm run run:node && npm run run:deno",
    "run:node": "node --test test/helpers/passing-tests.ts && node --test test/helpers/failing-tests.ts",
    "run:deno": "deno test test/helpers/passing-tests.ts && deno test test/helpers/failing-tests.ts",
    "changelog:unreleased": "git-cliff --unreleased --strip all",
    "changelog:preview": "git-cliff",
    "changelog:update": "git-cliff --output CHANGELOG.md",
    "prepare": "npm run build",
    "test": "npm run test:browser && npm run test:node && npm run test:deno",
    "test:release": "bash scripts/test-release.sh",
    "test:dev": "npm run test | tee test-output.log",
    "test:browser": "qunitx test/index.ts --debug",
    "test:deno": "deno test --allow-read --allow-run test/index.ts",
    "test:doctests": "deno test --doc --allow-read shims/deno/module.ts shims/deno/test.ts",
    "test:node": "node --test test/index.ts",
    "coverage": "deno test --coverage=tmp/coverage --allow-read --allow-env --allow-run test/index.ts && deno coverage --lcov --output=tmp/coverage/lcov.info --include='shims/' tmp/coverage && node scripts/check-coverage.ts",
    "coverage:report": "npm run coverage && deno coverage --html --include='shims/' tmp/coverage",
    "bench": "deno task bench",
    "bench:check": "deno task bench:check",
    "bench:update": "deno task bench:update",
    "docs": "deno doc --html --name=\"QUnitX\" --output=docs/src shims/deno/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.1",
    "qunit": "^2.25.0",
    "qunitx-cli": "^0.9.10",
    "typescript": "^6.0.2"
  },
  "volta": {
    "node": "24.14.0"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "arrowParens": "always"
  }
}
