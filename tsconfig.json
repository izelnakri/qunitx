{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "shims",
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "shims/node/**/*.ts",
    "shims/browser/**/*.ts",
    "shims/shared/**/*.ts",
    "shims/deno/**/*.ts",
    "shims/types.ts"
  ]
}
